{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchDepTypes": ["runtime"],
      "automerge": true,
      "labels": ["dependencies"]
    },
    {
      "matchDatasources": ["pip"],
      "matchDepTypes": ["runtime"],
      "automerge": true,
      "labels": ["dependencies"]
    }
  ],
  "docker": {
    "enabled": true,
    "fileMatch": ["(^|/)Dockerfile$"]
  },
  "pip": {
    "enabled": true,
    "fileMatch": ["(^|/)requirements-docker.txt$"]
  },
  "ignoreDeps": [
    "bump-my-version",
    "release-drafter"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "timezone": "UTC",
  "schedule": ["before 5am on Monday"]
}